# Primary LLM — get from aistudio.google.com
GEMINI_API_KEY=
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=

# Fallback LLM — get from console.groq.com
GROQ_API_KEY=

# Optional providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Provider/model defaults
API_PROVIDER=gemini
GEMINI_MODEL=gemini-1.5-flash

# Server config
PORT=8000
ENV=development

# Vector memory (ChromaDB + sentence-transformers)
VECTOR_MEMORY_ENABLED=true
VECTOR_EMBED_MODEL=all-MiniLM-L6-v2
